<style type="text/css">
  .template-404 .title + * {
    margin-top: 1rem;
  }

  @media screen and (min-width: 750px) {
    .template-404 .title + * {
      margin-top: 2rem;
    }
  }
</style>

<div class="template-404 page-width page-margin center">
  {% comment %} <p>
    {{ 'templates.404.subtext' | t }}
  </p> {% endcomment %}
  <h1 class="title">
    {{ 'templates.404.title' | t }}
  </h1>
  <a href="{{ routes.all_products_collection_url }}" class="button">
    {{ 'general.continue_shopping' | t }}
  </a>
</div>

<script>
  // Don't redirect if viewing in Shopify admin/theme editor (iframe)
  if (window.self === window.top) {
    setTimeout(function() {
      window.location.href = '/';
    }, 10000); // Redirect to home page after 10 seconds
  }
</script>

